# ============================================================
# Nexus Civic — Production Environment (.env.production)
# Copy this file and fill in your values:
#   cp .env.production.example .env.production
# ============================================================

# --- DATABASE (Docker internal MongoDB) ----------------------
MONGODB_URI=mongodb://mongodb:27017/nexus_civic

# --- AI (Required for full features) ------------------------
# Get free key from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# --- OPTIONAL AI SERVICES ------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- BLOCKCHAIN (mock mode - safe for demo) ------------------
SOLANA_ENABLED=false
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_PRIVATE_KEY=[]
SOLANA_PROGRAM_ID=

# --- AUTH ----------------------------------------------------
# IMPORTANT: Generate a real secret for production!
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_REAL_SECRET

# --- EXTERNAL DATA -------------------------------------------
GEE_MOCK=true
NEWS_API_KEY=

# --- OPTIONAL INTEGRATIONS -----------------------------------
SUPERPLANE_API_KEY=
ARMORIQ_API_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
SPACETIMEDB_URI=

# --- CORS (set to your Vultr IP or domain) -------------------
CORS_ORIGIN=http://YOUR_VULTR_IP

# --- FRONTEND URLs (Nginx proxies everything through port 80) -
# Replace YOUR_VULTR_IP with your actual server IP or domain
NEXT_PUBLIC_GUARDIAN_NET_URL=http://YOUR_VULTR_IP/api/guardian-net
NEXT_PUBLIC_PULSE_REPORT_URL=http://YOUR_VULTR_IP/api/pulse-report
NEXT_PUBLIC_CIVIC_PULSE_URL=http://YOUR_VULTR_IP/api/civic-pulse
NEXT_PUBLIC_SENTINEL_AI_URL=http://YOUR_VULTR_IP/api/sentinel-ai
NEXT_PUBLIC_VOICE_ASSEMBLY_URL=http://YOUR_VULTR_IP/api/voice-assembly
NEXT_PUBLIC_LEDGER_CIVIC_URL=http://YOUR_VULTR_IP/api/ledger-civic
NEXT_PUBLIC_MESH_ALERT_URL=http://YOUR_VULTR_IP/api/mesh-alert
NEXT_PUBLIC_AURA_ASSIST_URL=http://YOUR_VULTR_IP/api/aura-assist
