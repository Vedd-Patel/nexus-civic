{
  "name": "nexus-civic",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "MONGODB_URI=mongodb://127.0.0.1:27017/nexus_civic dotenv -e .env -- turbo run dev --concurrency=20",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "seed": "ts-node --project tsconfig.seed.json scripts/seed-db.ts",
    "smoke:mission": "bash scripts/smoke-mission-routes.sh",
    "smoke:mission:ci": "bash scripts/smoke-mission-routes-ci.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "dotenv-cli": "^11.0.0",
    "expo-module-scripts": "^55.0.2",
    "ts-node": "^10.9.0",
    "turbo": "^1.13.0",
    "typescript": "^5.3.0"
  }
}
